@model IEnumerable<UserManagementApp.Models.UserDocument>

@{
    ViewData["Title"] = "My Documents";
}

<div class="advanced-dashboard-container animate-fade-in">

    @if (TempData["Success"] != null)
    {
        <div style="background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 16px;">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 16px;">
            <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> @TempData["Error"]
        </div>
    }

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="font-size: 20px; font-weight: 700;"><i class="fas fa-file-lines" style="color: #6366f1; margin-right: 10px;"></i>My Documents</h2>
        <div style="display: flex; gap: 12px;">
            @if (Model.Any(d => d.Status == "Rejected"))
            {
                <a href="/Admin/Dashboard/Appeals" style="padding: 10px 24px; background: #ef4444; color: white; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none;">
                    <i class="fas fa-comment-dots" style="margin-right: 6px;"></i> Chat with Admin
                </a>
            }
            <a href="/Document/Upload" style="padding: 10px 24px; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none;">
                <i class="fas fa-cloud-arrow-up" style="margin-right: 6px;"></i> Upload Document
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 60px 20px; color: #94a3b8;">
            <i class="fas fa-folder-open" style="font-size: 48px; margin-bottom: 16px; color: #cbd5e1;"></i>
            <p style="font-size: 16px; font-weight: 600;">No documents uploaded yet</p>
            <p style="font-size: 14px;">Click "Upload Document" to add your first document</p>
        </div>
    }
    else
    {
        <div class="premium-table-card">
            <div class="table-responsive-wrapper">
                <table class="enterprise-matrix">
                    <thead>
                        <tr>
                            <th>Document Type</th>
                            <th>File Name</th>
                            <th>Upload Date</th>
                            <th>Status</th>
                            <th>View</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model)
                        {
                            <tr>
                                <td><span style="padding: 4px 12px; border-radius: 8px; font-size: 12px; font-weight: 600; background: rgba(99,102,241,0.1); color: #6366f1;">@doc.DocumentType</span></td>
                                <td style="font-weight: 500; max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@doc.DisplayFileName">@doc.DisplayFileName</td>
                                <td style="font-size: 13px; color: #64748b;">@doc.UploadedDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (doc.Status == "Approved")
                                    {
                                        <span style="padding: 4px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; background: rgba(16,185,129,0.1); color: #10b981;">✅ Approved</span>
                                    }
                                    else if (doc.Status == "Rejected")
                                    {
                                        <span style="padding: 4px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; background: rgba(239,68,68,0.1); color: #ef4444;">❌ Rejected</span>
                                    }
                                    else
                                    {
                                        <span style="padding: 4px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; background: rgba(245,158,11,0.1); color: #f59e0b;">⏳ Pending</span>
                                    }
                                </td>
                                <td>
                                    <div style="display: flex; gap: 12px; align-items: center;">
                                        <a href="@doc.FilePath" target="_blank" style="color: #6366f1; font-weight: 600; text-decoration: none;">
                                            <i class="fas fa-eye" style="margin-right: 4px;"></i> View
                                        </a>
                                        @if (doc.Status != "Approved")
                                        {
                                            <form action="/Document/Delete/@doc.DocumentId" method="post" style="margin: 0;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" style="background: none; border: none; color: #ef4444; font-weight: 600; cursor: pointer; padding: 0;" onclick="return confirm('Are you sure you want to delete this document?');">
                                                    <i class="fas fa-trash" style="margin-right: 4px;"></i> Delete
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span style="color: #94a3b8; font-weight: 600; font-size: 13px;">
                                                <i class="fas fa-lock" style="margin-right: 4px;"></i> Locked
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div style="margin-top: 16px;">
        <a href="/Admin/Dashboard" class="btn-premium-back"><i class="fas fa-arrow-left-long"></i> Back to Dashboard</a>
    </div>
</div>

