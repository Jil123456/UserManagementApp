@model UserManagementApp.Models.User
@{
    ViewData["Title"] = "Modify Record";
}

<div class="glass-card" style="width: 100%; max-width: 500px; padding: 45px;">
    <h4 class="text-gradient" style="font-size: 24px; margin-bottom: 30px; text-align: center;">Modify User Profile</h4>

    <form method="post">
        <input type="hidden" asp-for="UserId" />

        <div class="form-group">
            <input asp-for="Fullname" class="form-control" placeholder=" " />
            <label asp-for="Fullname">Full Name</label>
        </div>

        <div class="form-group">
            <input asp-for="Username" class="form-control" placeholder=" " />
            <label asp-for="Username">Username</label>
        </div>

        <div class="form-group">
            <input asp-for="Email" class="form-control" placeholder=" " />
            <label asp-for="Email">Email Address</label>
        </div>

        <div class="form-group">
            <input asp-for="Mobile" class="form-control" placeholder=" " />
            <label asp-for="Mobile">Mobile Number</label>
        </div>

        <button type="submit" class="btn-primary" style="margin-top: 15px;">
            Save Identity Mutations
        </button>
    </form>
</div>