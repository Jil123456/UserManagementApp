@model UserManagementApp.Models.User

@{
    ViewData["Title"] = "Account Rejected";
    var appeals = ViewBag.Appeals as List<UserManagementApp.Models.UserAppeal>;
}

<div class="auth-card" style="max-width: 900px; width: 100%; padding: 40px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 24px;">
        <i class="fas fa-user-xmark" style="font-size: 48px; color: #ef4444; margin-bottom: 16px;"></i>
        <h2 style="color: #ef4444; font-weight: 700; margin-bottom: 8px;">Account Rejected</h2>
        <p style="color: #64748b; font-size: 15px;">Your registration was rejected by the admin.</p>
    </div>

    <div style="background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 20px; margin-bottom: 24px;">
        <h4 style="color: #991b1b; font-size: 14px; font-weight: 700; margin-bottom: 8px; text-transform: uppercase;">Reason for Rejection</h4>
        <p style="color: #b91c1c; font-size: 15px; font-weight: 500; margin: 0;">@Model.RejectReason</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 24px;">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i> @TempData["Success"]
        </div>
    }

    <!-- Update Details Collapsible -->
    <div style="background: #1e293b; border: 1px solid #334155; border-radius: 12px; margin-bottom: 24px; overflow: hidden;">
        <button type="button" onclick="document.getElementById('update-details-form').classList.toggle('hidden-form')" 
                style="width: 100%; padding: 16px 20px; background: transparent; border: none; text-align: left; color: #f8fafc; font-size: 15px; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
            <span><i class="fas fa-user-pen" style="color: #3b82f6; margin-right: 8px;"></i> Fix Registration Details</span>
            <i class="fas fa-chevron-down" style="color: #64748b;"></i>
        </button>
        <div id="update-details-form" class="hidden-form" style="padding: 0 20px 20px 20px; border-top: 1px solid #334155;">
            <form asp-controller="Appeal" asp-action="UpdateDetails" method="post">
                @Html.AntiForgeryToken()
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; margin-top: 16px;">
                    <div>
                        <label class="lx-label">Full Name</label>
                        <input type="text" name="fullname" class="lx-input" value="@Model.Fullname" required />
                    </div>
                    <div>
                        <label class="lx-label">Email</label>
                        <input type="email" name="email" class="lx-input" value="@Model.Email" required />
                    </div>
                    <div>
                        <label class="lx-label">Mobile</label>
                        <input type="text" name="mobile" class="lx-input" value="@Model.Mobile" required />
                    </div>
                    <div>
                        <label class="lx-label">New Password</label>
                        <input type="password" name="password" class="lx-input" placeholder="(Leave blank to keep current)" />
                    </div>
                </div>
                <button type="submit" class="btn-primary" style="width: 100%;">
                    <i class="fas fa-save"></i> Save Changes & Ready for Appeal
                </button>
            </form>
        </div>
    </div>

    <style>
        .hidden-form { display: none; }
    </style>

    <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 16px; color: #f8fafc; display: flex; align-items: center; gap: 8px;">
        <i class="fas fa-messages text-gradient-sparkle"></i> Support Chat
    </h3>
    
    <div style="background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(12px); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); height: 380px; overflow-y: auto; padding: 20px; margin-bottom: 16px; display: flex; flex-direction: column; gap: 16px; box-shadow: inset 0 2px 10px rgba(0,0,0,0.2);" class="custom-scrollbar">
        @if (appeals == null || !appeals.Any())
        {
            <div style="text-align: center; color: #64748b; padding-top: 60px; font-size: 14px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                    <i class="fas fa-comment-dots" style="font-size: 28px; color: rgba(255,255,255,0.2);"></i>
                </div>
                <h4 style="color: #cbd5e1; margin-bottom: 4px; font-weight: 600;">No Messages Yet</h4>
                <span>Send a message to the admin to appeal your rejection.</span>
            </div>
        }
        else
        {
            @foreach(var appeal in appeals)
            {
                if (appeal.SentBy == "User")
                {
                    <!-- User message (right aligned) -->
                    <div style="align-self: flex-end; max-width: 75%; animation: lx-fade-up 0.3s ease-out;">
                        <div style="background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; padding: 12px 16px; border-radius: 20px; border-bottom-right-radius: 4px; font-size: 14.5px; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2); line-height: 1.5;">
                            @appeal.Message
                        </div>
                        <div style="font-size: 11px; color: #64748b; text-align: right; margin-top: 6px; font-weight: 500;">
                            You • @appeal.SentDate.ToLocalTime().ToString("MMM dd, hh:mm tt")
                        </div>
                    </div>
                }
                else
                {
                    <!-- Admin message (left aligned) -->
                    <div style="align-self: flex-start; max-width: 75%; animation: lx-fade-up 0.3s ease-out;">
                        <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; padding: 12px 16px; border-radius: 20px; border-bottom-left-radius: 4px; font-size: 14.5px; line-height: 1.5;">
                            @appeal.Message
                        </div>
                        <div style="font-size: 11px; color: #64748b; text-align: left; margin-top: 6px; font-weight: 500;">
                            <i class="fas fa-shield-check" style="color: #10b981; font-size: 10px; margin-right: 3px;"></i> Admin • @appeal.SentDate.ToLocalTime().ToString("MMM dd, hh:mm tt")
                        </div>
                    </div>
                }
            }
        }
    </div>

    <form asp-controller="Appeal" asp-action="SendMessage" method="post" style="display: flex; gap: 12px; align-items: stretch; background: rgba(15, 23, 42, 0.4); padding: 8px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
        @Html.AntiForgeryToken()
        <input type="text" name="message" class="lx-input" placeholder="Type your message to the admin..." required 
               style="flex: 1; border: none !important; background: transparent !important; margin: 0; box-shadow: none !important; color: white;" />
        <button type="submit" style="background: linear-gradient(135deg, #3b82f6, #6366f1); color: white; border: none; width: 44px; height: 44px; border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; box-shadow: 0 4px 10px rgba(59,130,246,0.3);"
                onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';">
            <i class="fas fa-paper-plane"></i>
        </button>
    </form>

    <div style="text-align: center; margin-top: 24px;">
        <a asp-controller="Auth" asp-action="Login" style="color: #64748b; text-decoration: none; font-size: 14px; font-weight: 500;">
            <i class="fas fa-arrow-left"></i> Back to Login
        </a>
    </div>
</div>

<script>
    // Scroll chat to bottom
    const chatContainer = document.querySelector('div[style*="overflow-y: auto"]');
    if (chatContainer) {
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
</script>
