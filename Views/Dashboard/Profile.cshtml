@model UserManagementApp.Models.User
@{
    ViewData["Title"] = "My Profile";
}

<div class="glass-card" style="width: 100%; max-width: 550px; margin: 0 auto;">
    <h3 style="font-size: 22px; margin-bottom: 25px; border-bottom: 1px solid #e2e8f0; padding-bottom: 15px; text-align: left;">
        My Account Profile
    </h3>

    <div style="display: flex; flex-direction: column; gap: 14px;">
        <div style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 14px 20px; border-radius: 10px; border: 1px solid #e2e8f0;">
            <span class="profile-label">Full Name</span>
            <span class="profile-value">@Model.Fullname</span>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 14px 20px; border-radius: 10px; border: 1px solid #e2e8f0;">
            <span class="profile-label">Username Handle</span>
            <span class="profile-value">@@@Model.Username</span>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 14px 20px; border-radius: 10px; border: 1px solid #e2e8f0;">
            <span class="profile-label">Email Address</span>
            <span class="profile-value">@Model.Email</span>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 14px 20px; border-radius: 10px; border: 1px solid #e2e8f0;">
            <span class="profile-label">Mobile Terminal</span>
            <span class="profile-value">@Model.Mobile</span>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 14px 20px; border-radius: 10px; border: 1px solid #e2e8f0;">
            <span class="profile-label">System Clearances</span>
            <span class="@(Model.RoleId == 1 ? "badge-admin" : "badge-user")">
                @(Model.RoleId == 1 ? "Admin" : "User")
            </span>
        </div>
    </div>

    <div style="margin-top: 35px; padding-top: 25px; border-top: 1px solid #e2e8f0;">
        <a asp-controller="Dashboard" asp-action="Dashboard" class="btn-primary" style="display: block; text-align: center; width: 100%; border-radius: 25px !important;">
            Back to Application Dashboard
        </a>
    </div>
</div>