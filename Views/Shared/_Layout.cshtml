<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@if (Context.Session.GetString("Username") == null)
{
    @RenderBody()
}
else
{
    <div class="app-shell">

        <header class="app-topbar">
            <div class="brand"><i class="fa-solid fa-cube"></i> &nbsp; USERHUB</div>
            <div class="user-area">
                <span class="who"><i class="fa-solid fa-user-circle"></i> &nbsp; @Context.Session.GetString("Username")</span>
                <a asp-controller="Account" asp-action="Logout" class="btn-logout">Logout</a>
            </div>
        </header>

        <aside class="app-sidebar">
            <h3>Menu</h3>
            <a asp-controller="Home" asp-action="Dashboard" class="nav-link"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a asp-controller="User" asp-action="Profile" class="nav-link"><i class="fa-solid fa-user"></i> Profile</a>
            @if (Context.Session.GetInt32("RoleId") == 1)
            {
                <a asp-controller="User" asp-action="UserList" class="nav-link"><i class="fa-solid fa-users"></i> Manage Users</a>
            }
        </aside>

        <main class="app-main">
            @RenderBody()
        </main>

    </div>
}

</body>
</html>
