<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var isUnauth = Context.Session.GetString("Username") == null;
    var roleId = Context.Session.GetInt32("RoleId");
    var isAdmin = roleId == 1 || roleId == 3;
}
<body>
    @if (isUnauth)
    {
        <div class="auth-page-centered-wrapper">
            @RenderBody()
        </div>
    }
    else
    {
        <div class="app-layout">
            <aside class="sidebar">
                <div class="sidebar-logo"><span>🚀</span> UserHub</div>
                <nav class="sidebar-menu">
                    <a href="/Admin/Dashboard" class="menu-item">
                        <i class="fas fa-home"></i> Dashboard
                    </a>
                    <a href="/Admin/Dashboard/Profile" class="menu-item">
                        <i class="fas fa-user"></i> Profile
                    </a>
                    @if (isAdmin)
                    {
                        <a href="/Admin/User" class="menu-item">
                            <i class="fas fa-users-gear"></i> Manage Users
                        </a>
                        @if (roleId == 3)
                        {

                            <a href="/Admin/AdminDoc/KycDashboard" class="menu-item">
                                <i class="fas fa-file-signature"></i> KYC Dashboard
                            </a>
                            <a href="/Admin/Audit" class="menu-item">
                                <i class="fas fa-journal-whills"></i> Audit Logs
                            </a>
                        }
                    }
                </nav>
            </aside>

            <div class="main-area">
                <div class="topbar">
                    <div class="topbar-left">
                        <h3>@ViewData["Title"]</h3>
                    </div>

                    <div class="topbar-right">
                        <span class="username">
                            <i class="fas fa-user-circle"></i> @(Context.Session.GetString("Username") ?? "Operator")
                            @if (roleId == 3)
                            {
                                <span style="background: linear-gradient(135deg,#7c3aed,#ca8a04); color: #fff; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; margin-left: 8px;">SUPER ADMIN</span>
                            }
                            else if (roleId == 1)
                            {
                                <span style="background: linear-gradient(135deg,#7c3aed,#ca8a04); color: #fff; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; margin-left: 8px;">ADMIN</span>
                            }
                        </span>
                        <a href="/Auth/Logout" class="btn-logout">
                            <i class="fas fa-right-from-bracket"></i> Logout
                        </a>
                    </div>
                </div>

                <main class="content-area">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
</body>
</html>