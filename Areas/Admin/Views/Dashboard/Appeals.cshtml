@model UserManagementApp.Models.User

@{
    ViewData["Title"] = "Appeals & Chat";
    var appeals = ViewBag.Appeals as List<UserManagementApp.Models.UserAppeal>;
}

<div class="advanced-dashboard-container animate-fade-in">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 style="font-size: 20px; font-weight: 700;">
            <i class="fas fa-comment-dots text-gradient-sparkle" style="margin-right: 10px;"></i>
            Chat with Admin
        </h2>
        <a href="/Admin/Dashboard/Index" class="btn-secondary" style="padding: 8px 16px;">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <!-- Chat/Appeals History -->
    <div style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); border-radius: 20px; border: 1px solid rgba(226, 232, 240, 0.8); padding: 24px; margin-bottom: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
        <h4 style="font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 20px;"><i class="fas fa-history" style="color: #64748b; margin-right: 8px;"></i> Conversation History</h4>

        <div style="height: 350px; overflow-y: auto; padding-right: 12px; display: flex; flex-direction: column; gap: 16px;" class="custom-scrollbar">
            @if (appeals == null || !appeals.Any())
            {
                <div style="text-align: center; padding: 60px 20px; color: #94a3b8; background: rgba(248, 250, 252, 0.5); border-radius: 16px; border: 1px dashed #cbd5e1; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                    <div style="width: 64px; height: 64px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                        <i class="fas fa-messages" style="font-size: 24px; color: #cbd5e1;"></i>
                    </div>
                    <p style="font-weight: 500;">No messages yet. Send a message below to appeal your rejection or ask a question.</p>
                </div>
            }
            else
            {
                @foreach (var appeal in appeals)
                {
                    bool isUser = appeal.SentBy == "User";
                    <div style="display: flex; flex-direction: column; align-items: @(isUser ? "flex-end" : "flex-start"); animation: lx-fade-up 0.3s ease-out;">
                        <div style="max-width: 75%; padding: 14px 18px; border-radius: 20px; font-size: 14.5px; line-height: 1.5;
                                    @(isUser ? "background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border-bottom-right-radius: 4px; box-shadow: 0 6px 16px rgba(37,99,235,0.25);" 
                                             : "background: #f1f5f9; color: #1e293b; border-bottom-left-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.03); border: 1px solid #e2e8f0;")">
                            @appeal.Message
                        </div>
                        <div style="font-size: 11px; color: #94a3b8; font-weight: 600; margin-top: 6px; padding: 0 4px;">
                            @(isUser ? "You" : "Admin") • @appeal.SentDate.ToLocalTime().ToString("MMM dd, hh:mm tt")
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Send Message Form -->
    <form asp-area="Admin" asp-controller="Dashboard" asp-action="SendAppealMessage" method="post" style="display: flex; gap: 12px; background: white; padding: 10px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 6px 15px rgba(0,0,0,0.03); align-items: center;">
        @Html.AntiForgeryToken()
        <input type="text" name="message" placeholder="Write your message... (e.g. 'I re-uploaded my Aadhar card')" required style="flex: 1; border: none !important; outline: none !important; background: transparent !important; padding: 0 16px; font-size: 15px; color: #1e293b; box-shadow: none !important;" autocomplete="off" />
        <button type="submit" style="background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; border: none; width: 44px; height: 44px; border-radius: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; box-shadow: 0 4px 10px rgba(59,130,246,0.3);"
                onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';">
            <i class="fas fa-paper-plane"></i>
        </button>
    </form>
</div>
