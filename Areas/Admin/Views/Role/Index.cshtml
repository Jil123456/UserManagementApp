@model IEnumerable<UserManagementApp.Models.RoleMaster>

@{
    ViewData["Title"] = "Manage Roles";
}

<div class="advanced-dashboard-container animate-fade-in">

    @if (TempData["Success"] != null)
    {
        <div style="background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 16px;">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 16px;">
            <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> @TempData["Error"]
        </div>
    }

    <!-- ADD NEW ROLE -->
    <div class="premium-table-card" style="margin-bottom: 24px;">
        <div class="table-utility-bar">
            <div class="identity-info">
                <span class="profile-name" style="font-size: 16px;"><i class="fas fa-plus-circle" style="color: #10b981; margin-right: 8px;"></i> Add New Role</span>
            </div>
        </div>
        <div style="padding: 20px 24px;">
            <form action="/Admin/Role/Create" method="post" style="display: flex; gap: 12px; align-items: center;">
                @Html.AntiForgeryToken()
                <input type="text" name="RoleName" placeholder="Enter role name (e.g. Manager)" required
                       style="flex: 1; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 10px; font-size: 14px; font-family: 'Inter', sans-serif; outline: none;" />
                <button type="submit" style="padding: 12px 28px; background: linear-gradient(135deg, #10b981, #059669); color: white; border: none; border-radius: 10px; font-weight: 700; font-size: 14px; cursor: pointer; font-family: 'Inter', sans-serif;">
                    <i class="fas fa-plus" style="margin-right: 6px;"></i> Add Role
                </button>
            </form>
        </div>
    </div>

    <!-- ROLE LIST -->
    <div class="premium-table-card">
        <div class="table-utility-bar">
            <div class="identity-info">
                <span class="profile-name" style="font-size: 16px;"><i class="fas fa-shield-halved" style="color: #6366f1; margin-right: 8px;"></i> Role Master</span>
                <span class="profile-status-indicator">All roles in the system</span>
            </div>
            <div class="live-pulse-badge">
                <span class="pulse-dot"></span> @Model.Count() Roles
            </div>
        </div>

        <div class="table-responsive-wrapper">
            <table class="enterprise-matrix">
                <thead>
                    <tr>
                        <th>Role ID</th>
                        <th>Role Name</th>
                        <th style="text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td><span style="font-weight: 700; color: #6366f1;">#@role.RoleId</span></td>
                            <td>
                                @if (role.RoleId <= 3)
                                {
                                    <div style="padding: 8px 14px; font-size: 14px; font-weight: 600; color: #475569;">
                                        @role.RoleName <span style="margin-left: 8px; font-size: 11px; background: rgba(16,185,129,0.1); color: #10b981; padding: 2px 8px; border-radius: 12px;">Core Role</span>
                                    </div>
                                }
                                else
                                {
                                    <form action="/Admin/Role/Edit" method="post" style="display: flex; align-items: center; gap: 10px; margin: 0;" id="editForm_@role.RoleId">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="RoleId" value="@role.RoleId" />
                                        <input type="text" name="RoleName" value="@role.RoleName" required
                                               style="padding: 8px 14px; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 14px; font-family: 'Inter', sans-serif; width: 200px; outline: none;" />
                                        <button type="submit" style="padding: 8px 16px; background: #6366f1; color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 13px; cursor: pointer; font-family: 'Inter', sans-serif;">
                                            <i class="fas fa-save" style="margin-right: 4px;"></i> Save
                                        </button>
                                    </form>
                                }
                            </td>
                            <td style="text-align: center;">
                                @if (role.RoleId <= 3)
                                {
                                    <span style="font-size: 13px; color: #94a3b8; font-weight: 600;">
                                        <i class="fas fa-lock" style="margin-right: 4px;"></i> Protected
                                    </span>
                                }
                                else
                                {
                                    <form action="/Admin/Role/Delete" method="post" style="display: flex; flex-direction: column; align-items: center; gap: 6px; margin: 0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@role.RoleId" />
                                        <select name="transferRoleId" style="padding: 6px 10px; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 11px; font-family: 'Inter', sans-serif; outline: none; background: white; width: 140px;">
                                            <option value="">-- Transfer Users To --</option>
                                            @foreach (var r in Model.Where(x => x.RoleId != role.RoleId && x.RoleId != 3))
                                            {
                                                <option value="@r.RoleId">@r.RoleName</option>
                                            }
                                        </select>
                                        <button type="submit" onclick="return confirm('Are you sure you want to delete this role? Any users will be transferred to the selected role.')"
                                                style="padding: 6px 16px; background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; font-weight: 600; font-size: 12px; cursor: pointer; font-family: 'Inter', sans-serif; width: 140px;">
                                            <i class="fas fa-trash-can" style="margin-right: 4px;"></i> Delete Role
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div style="margin-top: 16px;">
        <a href="/Admin/Dashboard" class="btn-premium-back">
            <i class="fas fa-arrow-left-long"></i> Back to Dashboard
        </a>
    </div>
</div>
