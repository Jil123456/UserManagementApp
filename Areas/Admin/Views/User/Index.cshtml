@model IEnumerable<UserManagementApp.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="advanced-dashboard-container animate-fade-in">

    @if (TempData["Success"] != null)
    {
        <div style="background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 16px;">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 14px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; margin-bottom: 16px;">
            <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> @TempData["Error"]
        </div>
    }

    <div class="premium-table-card">
        <div class="table-utility-bar">
            <div class="identity-info">
                <span class="profile-name" style="font-size: 16px;"><i class="fas fa-users-viewfinder" style="color: #6366f1; margin-right: 8px;"></i> User Registry Matrix</span>
                <span class="profile-status-indicator">All registered users in the system</span>
            </div>
            <div class="live-pulse-badge">
                <span class="pulse-dot"></span> @Model.Count() Users Found
            </div>
        </div>

        <div class="table-responsive-wrapper">
            <table class="enterprise-matrix">
                <thead>
                    <tr>
                        <th>Identity</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th style="text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="identity-cell">
                                    <div class="avatar-circle @(user.RoleId == 1 || user.RoleId == 3 ? "avatar-grad-admin" : "avatar-grad-user")">
                                        @(user.Fullname?.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="profile-name text-capitalize">@user.Fullname</div>
                                        <div class="profile-status-indicator">
                                            <span class="@(user.RoleId == 1 || user.RoleId == 3 ? "dot-admin-live" : "dot-user-live")"></span>
                                            @(user.RoleName ?? (user.RoleId == 3 ? "Super Administrator" : (user.RoleId == 1 ? "Administrator" : "Standard User")))
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="handle-tag @(user.RoleId == 1 || user.RoleId == 3 ? "handle-admin" : "handle-user")">@@@user.Username</span></td>
                            <td><a href="mailto:@user.Email" class="matrix-email-link">@user.Email</a></td>
                            <td class="font-mono">@user.Mobile</td>
                            <td>
                                @if (user.RoleId == 3)
                                {
                                    <span class="handle-tag handle-admin" style="background: rgba(139,92,246,0.1); color: #8b5cf6; border-color: rgba(139,92,246,0.2);"><i class="fas fa-crown" style="margin-right: 4px;"></i> @(user.RoleName ?? "Super Admin")</span>
                                }
                                else if (user.RoleId == 1)
                                {
                                    <span class="handle-tag handle-admin"><i class="fas fa-crown" style="margin-right: 4px;"></i> @(user.RoleName ?? "Admin")</span>
                                }
                                else
                                {
                                    <span class="handle-tag handle-user"><i class="fas fa-user" style="margin-right: 4px;"></i> @(user.RoleName ?? "User")</span>
                                }
                            </td>
                            <td>
                                @if (user.Status == "Approved")
                                {
                                    <span style="padding: 4px 12px; border-radius: 8px; font-size: 11px; font-weight: 700; background: rgba(16,185,129,0.1); color: #10b981; display: inline-block; margin-bottom: 4px;"><i class="fas fa-check-circle" style="margin-right: 3px;"></i>Approved</span>
                                    @if (!string.IsNullOrEmpty(user.ActionByAdmin))
                                    {
                                        <div style="font-size: 10px; color: #6b7280; margin-top: 2px;">By: @user.ActionByAdmin</div>
                                    }
                                }
                                else if (user.Status == "Rejected")
                                {
                                    <span style="padding: 4px 12px; border-radius: 8px; font-size: 11px; font-weight: 700; background: rgba(239,68,68,0.1); color: #ef4444; display: inline-block; margin-bottom: 4px;"><i class="fas fa-times-circle" style="margin-right: 3px;"></i>Rejected</span>
                                    @if (!string.IsNullOrEmpty(user.ActionByAdmin))
                                    {
                                        <div style="font-size: 10px; color: #6b7280; margin-top: 2px;">By: @user.ActionByAdmin</div>
                                    }
                                }
                                else
                                {
                                    <span style="padding: 4px 12px; border-radius: 8px; font-size: 11px; font-weight: 700; background: rgba(245,158,11,0.1); color: #f59e0b;"><i class="fas fa-clock" style="margin-right: 3px;"></i>Pending</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                                    <!-- EDIT BUTTON — simple link to /Admin/User/Edit/{id} -->
                                    <a href="/Admin/User/Edit/@user.UserId"
                                       style="display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 10px; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2); color: #818cf8; font-size: 14px; text-decoration: none; transition: all 0.2s ease;"
                                       title="Edit User"
                                       onmouseover="this.style.background='rgba(99,102,241,0.2)'; this.style.transform='translateY(-1px)'"
                                       onmouseout="this.style.background='rgba(99,102,241,0.1)'; this.style.transform='translateY(0)'">
                                       <i class="fas fa-pen"></i>
                                    </a>


                                      <!-- DEACTIVATE / REACTIVATE BUTTONS -->
                                      @if (user.IsActive)
                                      {
                                          bool canDeactivate = false;
                                          var currentRoleId = Context.Session.GetInt32("RoleId");
                                          if (user.RoleId != 3) // Nobody can deactivate Super Admin
                                          {
                                              if (currentRoleId == 3) canDeactivate = true; // Super Admin can deactivate anyone else
                                              else if (currentRoleId == 1 && user.RoleId != 1) canDeactivate = true; // Admin can only deactivate Users
                                          }

                                          if (canDeactivate)
                                          {
                                              <form action="/Admin/User/Deactivate/@user.UserId" method="post" style="margin: 0; padding: 0;">
                                                  @Html.AntiForgeryToken()
                                                  <input type="hidden" name="id" value="@user.UserId" />
                                                  @if (user.RoleId == 1)
                                                  {
                                                      <button type="submit"
                                                              style="display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 10px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #f87171; font-size: 14px; cursor: pointer; transition: all 0.2s ease;"
                                                              title="Deactivate Admin"
                                                              onmouseover="this.style.background='rgba(239,68,68,0.2)'; this.style.transform='translateY(-1px)'"
                                                              onmouseout="this.style.background='rgba(239,68,68,0.1)'; this.style.transform='translateY(0)'"
                                                              onclick="return confirm('⚠️ WARNING: You are about to deactivate an ADMIN account!\n\nAre you sure?\nThis action will prevent them from logging in.')">
                                                          <i class="fas fa-user-slash"></i>
                                                      </button>
                                                  }
                                                  else
                                                  {
                                                      <button type="submit"
                                                              style="display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 10px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #f87171; font-size: 14px; cursor: pointer; transition: all 0.2s ease;"
                                                              title="Deactivate User"
                                                              onmouseover="this.style.background='rgba(239,68,68,0.2)'; this.style.transform='translateY(-1px)'"
                                                              onmouseout="this.style.background='rgba(239,68,68,0.1)'; this.style.transform='translateY(0)'"
                                                              onclick="return confirm('Are you sure you want to deactivate this user?')">
                                                          <i class="fas fa-user-slash"></i>
                                                      </button>
                                                  }
                                              </form>
                                          }
                                      }
                                      else
                                      {
                                          @if (Context.Session.GetInt32("RoleId") == 3)
                                          {
                                              <form action="/Admin/User/Reactivate/@user.UserId" method="post" style="margin: 0; padding: 0;">
                                                  @Html.AntiForgeryToken()
                                                  <input type="hidden" name="id" value="@user.UserId" />
                                                  <button type="submit"
                                                          style="display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 10px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); color: #22c55e; font-size: 14px; cursor: pointer; transition: all 0.2s ease;"
                                                          title="Reactivate User"
                                                          onmouseover="this.style.background='rgba(34,197,94,0.2)'; this.style.transform='translateY(-1px)'"
                                                          onmouseout="this.style.background='rgba(34,197,94,0.1)'; this.style.transform='translateY(0)'"
                                                          onclick="return confirm('Are you sure you want to reactivate this user?')">
                                                      <i class="fas fa-user-check"></i>
                                                  </button>
                                              </form>
                                          }
                                      }


                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div style="margin-top: 16px;">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn-premium-back">
            <i class="fas fa-arrow-left-long"></i> Back to Dashboard
        </a>
    </div>
</div>
