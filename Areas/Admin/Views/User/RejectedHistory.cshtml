@model IEnumerable<UserManagementApp.Models.User>

@{
    ViewData["Title"] = "Rejected Users History";
}

<div class="advanced-dashboard-container animate-fade-in">
    <div class="premium-table-card">
        <div class="table-utility-bar">
            <div class="identity-info">
                <span class="profile-name" style="font-size: 16px;"><i class="fas fa-user-times" style="color: #ef4444; margin-right: 8px;"></i> Rejected Users History</span>
                <span class="profile-status-indicator">Log of all rejected registrations and reasons</span>
            </div>
            <div class="live-pulse-badge" style="background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2);">
                <span class="pulse-dot" style="background: #ef4444; box-shadow: 0 0 8px #ef4444;"></span> @Model.Count() Records
            </div>
        </div>

        <div class="table-responsive-wrapper">
            <table class="enterprise-matrix">
                <thead>
                    <tr>
                        <th>Identity</th>
                        <th>Contact</th>
                        <th>Rejected By</th>
                        <th>Rejection Reason</th>
                        <th style="text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="identity-cell">
                                    <div class="avatar-circle avatar-grad-user">
                                        @(user.Fullname?.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="profile-name text-capitalize">@user.Fullname</div>
                                        <div class="profile-status-indicator">
                                            <span class="handle-user">@@@user.Username</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-size: 13px; color: #475569;">@user.Email</div>
                                <div class="font-mono" style="font-size: 12px; color: #64748b; margin-top: 2px;">@user.Mobile</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.ActionByAdmin))
                                {
                                    <span style="font-weight: 600; color: #475569;"><i class="fas fa-shield-halved" style="margin-right: 4px; color: #94a3b8;"></i>@user.ActionByAdmin</span>
                                }
                                else
                                {
                                    <span style="color: #94a3b8; font-style: italic;">Unknown</span>
                                }
                            </td>
                            <td>
                                <div style="max-width: 250px; background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.1); padding: 8px 12px; border-radius: 8px; font-size: 13px; color: #b91c1c;">
                                    @(string.IsNullOrEmpty(user.RejectReason) ? "No reason provided" : user.RejectReason)
                                </div>
                            </td>
                            <td>
                                <div style="display: flex; align-items: center; justify-content: center;">
                                    <a href="/Admin/User/Appeals/@user.UserId"
                                       style="display: inline-flex; align-items: center; justify-content: center; padding: 6px 12px; border-radius: 8px; background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2); color: #3b82f6; font-size: 13px; font-weight: 600; text-decoration: none; transition: all 0.2s ease;"
                                       title="View Appeals">
                                        <i class="fas fa-comment-dots" style="margin-right: 6px;"></i> View Appeal
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px; color: #64748b;">
                                <i class="fas fa-folder-open" style="font-size: 24px; color: #cbd5e1; margin-bottom: 12px; display: block;"></i>
                                No rejected users found in history.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div style="margin-top: 16px;">
        <a href="/Admin/Dashboard" class="btn-premium-back">
            <i class="fas fa-arrow-left-long"></i> Back to Dashboard
        </a>
    </div>
</div>
