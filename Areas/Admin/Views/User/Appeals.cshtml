@model UserManagementApp.Models.User

@{
    ViewData["Title"] = "User Appeals";
    var appeals = ViewBag.Appeals as List<UserManagementApp.Models.UserAppeal>;
}

<div class="advanced-dashboard-container animate-fade-in">
    <div style="width: 100%; margin: 0 auto; background: white; border-radius: 16px; border: 1px solid #e2e8f0; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -2px rgba(0,0,0,0.05);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #f1f5f9;">
            <div style="display: flex; align-items: center; gap: 16px;">
                <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <h2 style="font-size: 18px; font-weight: 700; margin: 0; color: #1e293b;">@Model.Fullname</h2>
                    <div style="font-size: 13px; color: #64748b; margin-top: 2px;">
                        @@@Model.Username • Status: 
                        @if (Model.Status == "Approved")
                        {
                            <span style="color: #10b981; font-weight: 600;">Active</span>
                        }
                        else
                        {
                            <span style="color: #ef4444; font-weight: 600;">@Model.Status</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.ActionByAdmin))
                        {
                            <span style="color: #64748b; font-weight: 500; margin-left: 6px;">(by @Model.ActionByAdmin)</span>
                        }
                    </div>
                </div>
            </div>
            @if (Model.Status != "Approved")
            {
                <form action="/Admin/User/Approve" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.UserId" />
                    <button type="submit" class="btn-primary" style="background: #10b981; box-shadow: 0 4px 12px rgba(16,185,129,0.2);" onclick="return confirm('Approve this user and allow them to login?')">
                        <i class="fas fa-check"></i> Approve User
                    </button>
                </form>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.RejectReason) && Model.Status == "Rejected")
        {
            <div style="background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 16px; margin-bottom: 24px;">
                <div style="font-size: 12px; font-weight: 700; color: #991b1b; text-transform: uppercase; margin-bottom: 4px;"><i class="fas fa-info-circle"></i> Original Rejection Reason</div>
                <div style="font-size: 14px; color: #b91c1c;">@Model.RejectReason</div>
            </div>
        }

        <!-- Chat Area -->
        <div style="background: rgba(248, 250, 252, 0.8); backdrop-filter: blur(12px); border-radius: 20px; border: 1px solid rgba(226, 232, 240, 0.8); height: 450px; overflow-y: auto; padding: 24px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 16px; box-shadow: inset 0 2px 10px rgba(0,0,0,0.02);" class="custom-scrollbar">
            @if (appeals == null || !appeals.Any())
            {
                <div style="text-align: center; color: #94a3b8; padding-top: 100px; font-size: 14px; display: flex; flex-direction: column; align-items: center;">
                    <div style="width: 64px; height: 64px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                        <i class="fas fa-messages" style="font-size: 24px; color: #cbd5e1;"></i>
                    </div>
                    <span style="font-weight: 500;">No messages yet. Send a message to start the conversation.</span>
                </div>
            }
            else
            {
                @foreach(var appeal in appeals)
                {
                    if (appeal.SentBy == "Admin")
                    {
                        <!-- Admin message (right aligned) -->
                        <div style="align-self: flex-end; max-width: 75%; animation: lx-fade-up 0.3s ease-out;">
                            <div style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; padding: 14px 18px; border-radius: 20px; border-bottom-right-radius: 4px; font-size: 14.5px; box-shadow: 0 6px 16px rgba(99,102,241,0.25); line-height: 1.5;">
                                @appeal.Message
                            </div>
                            <div style="font-size: 11px; color: #94a3b8; text-align: right; margin-top: 6px; font-weight: 600;">
                                You • @appeal.SentDate.ToLocalTime().ToString("MMM dd, hh:mm tt")
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- User message (left aligned) -->
                        <div style="align-self: flex-start; max-width: 75%; animation: lx-fade-up 0.3s ease-out;">
                            <div style="background: white; border: 1px solid #e2e8f0; color: #1e293b; padding: 14px 18px; border-radius: 20px; border-bottom-left-radius: 4px; font-size: 14.5px; box-shadow: 0 4px 10px rgba(0,0,0,0.03); line-height: 1.5;">
                                @appeal.Message
                            </div>
                            <div style="font-size: 11px; color: #94a3b8; text-align: left; margin-top: 6px; font-weight: 600;">
                                @Model.Fullname • @appeal.SentDate.ToLocalTime().ToString("MMM dd, hh:mm tt")
                            </div>
                        </div>
                    }
                }
            }
        </div>

        <form asp-area="Admin" asp-controller="User" asp-action="SendAppealMessage" method="post" style="display: flex; gap: 12px; background: white; padding: 10px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 6px 15px rgba(0,0,0,0.03); align-items: center;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@Model.UserId" />
            <input type="text" name="message" placeholder="Type a response to the user..." required style="flex: 1; border: none !important; outline: none !important; background: transparent !important; padding: 0 16px; font-size: 15px; color: #1e293b; box-shadow: none !important;" autocomplete="off" />
            <button type="submit" style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; border: none; width: 44px; height: 44px; border-radius: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; box-shadow: 0 4px 10px rgba(99,102,241,0.3);"
                    onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>

        <div style="margin-top: 24px; padding-top: 16px; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end;">
            <a href="javascript:history.back()" class="btn-secondary" style="display: inline-flex; border-radius: 10px; padding: 10px 20px; text-decoration: none;">
                <i class="fas fa-arrow-left" style="margin-right: 6px;"></i> Go Back
            </a>
        </div>
    </div>
</div>

<script>
    // Scroll chat to bottom
    const chatContainer = document.querySelector('div[style*="overflow-y: auto"]');
    if (chatContainer) {
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
</script>
